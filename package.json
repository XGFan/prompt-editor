{
  "name": "prompt-editor-sdk",
  "private": false,
  "version": "0.0.0",
  "description": "PromptEditorSDK package for host app integration",
  "type": "module",
  "main": "./dist-sdk/index.cjs",
  "module": "./dist-sdk/index.js",
  "types": "./dist-sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-sdk/index.d.ts",
      "import": "./dist-sdk/index.js",
      "require": "./dist-sdk/index.cjs"
    },
    "./style.css": "./dist-sdk/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist-sdk",
    "README.md",
    "docs/SDK_FOR_LLM.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "tauri:precheck": "node scripts/tauri-precheck.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --bundles app",
    "e2e": "playwright test",
    "e2e:list": "playwright test --list",
    "build:sdk:bundle": "vite build -c vite.sdk.config.ts",
    "build:sdk:types": "node scripts/build-sdk-dts.mjs",
    "build:sdk": "npm run build:sdk:bundle && npm run build:sdk:types",
    "pack:sdk": "npm run build:sdk && mkdir -p dist-pack && npm pack --pack-destination ./dist-pack",
    "pack:sdk:dry-run": "npm pack --dry-run"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.24",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
